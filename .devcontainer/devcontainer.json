{
    "name": "MacroModelling.jl",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "julialang.language-julia",
                "bungcip.better-toml"
            ],
            "settings": {
                "julia.executablePath": "/usr/local/julia/bin/julia"
            }
        }
    },
    "onCreateCommand": "julia --project=. -e 'using Pkg; Pkg.instantiate(); Pkg.precompile()'",
    "remoteUser": "vscode"
}
